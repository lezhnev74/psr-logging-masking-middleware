{
    "name": "lezhnev74/guzzle-logging-masking-middleware",
    "description": "A Guzzle middleware that logs every request/response through a PSR-3 logger, with headers, query args and body keys masked. Built on PSR-7 and PSR-3.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "guzzle",
        "psr-7",
        "psr-3",
        "logging",
        "middleware",
        "masking",
        "redaction"
    ],
    "authors": [
        {
            "name": "Dmitry Lezhnev",
            "email": "lezhnev.work@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "psr/http-message": "^1.1 || ^2.0",
        "psr/log": "^2.0 || ^3.0",
        "guzzlehttp/guzzle": "^7.0 || ^8.0",
        "guzzlehttp/psr7": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.12",
        "friendsofphp/php-cs-fixer": "^3.64",
        "rector/rector": "^1.2"
    },
    "autoload": {
        "psr-4": {
            "Lezhnev74\\GuzzleLoggingMiddleware\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lezhnev74\\GuzzleLoggingMiddleware\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "rector": "rector process --dry-run",
        "check": [
            "@cs",
            "@stan",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
